# Copy this file to .env and replace the example values before starting Compose.
POSTGRES_DB=agriconnect
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password-for-db

# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_EXPIRATION=3600000

# Optional. Leave empty while AI_PROVIDER=mock.
AI_API_KEY=

# Public URL embedded in the frontend image during build.
VITE_API_URL=http://localhost:8080/api
